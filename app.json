{
  "expo": {
    "name": "Vibesom",
    "slug": "vibesom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fd-entrar.png",
    "scheme": "vibesom",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/fd-entrar.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/fd-entrar.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.ffreita_s.vibesom"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/fd-entrar.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11dcefc8-d61b-49db-a917-53534c3cdf11"
      }
    }
  }
}
